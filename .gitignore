# ─── Secrets (NEVER commit) ──────────────────────────────────────────────────
# Environment files with API keys, DB URLs, shared secrets, etc.
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Auth databases — contain PBKDF2 password hashes and live session tokens
auth.db
*.db
*.sqlite
*.sqlite3
*.sqlite-journal
*.db-journal
# SQLite WAL / shared-memory temp files
*.db-shm
*.db-wal

# Local /loop session save patches (scripts/save_session.sh output)
saves/
**/saves/

# Private keys / credentials
*.key
.secret_key
**/.secret_key
*.pem
*.p12
*.pfx
credentials*
*credentials*
*.cert
*.crt

# Cloudflare tunnel credentials
.cloudflared/
*.cloudflared.json

# ─── Python build artifacts ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv/
.env/
**/venv/
**/env/
**/.venv/

# Testing / linting caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
.hypothesis/

# ─── Node / frontend ─────────────────────────────────────────────────────────
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next/
.nuxt/
.turbo/
.parcel-cache/

# ─── Logs & bot state files (often have PII / account data) ──────────────────
*.log
logs/
**/logs/
bot_activity.log
*_activity.log
*_bot.log

# ─── Data dumps / backups / caches (too big or sensitive) ────────────────────
*.parquet
*.pkl
*.pickle
*.joblib
*.h5
*.hdf5
*.npy
*.npz
data_cache/
cache/
.cache/
# Exception: gateway/cache/ is a source-code package, not a data cache
!gateway/cache/
!gateway/cache/*
Polymarket_backup_*/
.backup_*/
**/.backup_*/

# Scratch / work-in-progress directory with orphaned copies of files
workdir/

# Trade histories and market snapshots — may contain strategy signal
stock_trades.json
stock_trades_backup.json
bot_trades.json
suspicious_trades.json

# ─── IDE / OS cruft ──────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# ─── Claude Code / AI tooling scratch ────────────────────────────────────────
.claude/
CLAUDE.md.local
.anthropic/

# ─── Runtime PID / lock files ────────────────────────────────────────────────
*.pid
*.lock
!package-lock.json
!pnpm-lock.yaml
!yarn.lock
!poetry.lock
!Pipfile.lock
!uv.lock
