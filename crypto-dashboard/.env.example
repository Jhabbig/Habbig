# The Odds API - get a free key at https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# Polymarket CLOB API host
POLYMARKET_HOST=https://clob.polymarket.com

# Divergence threshold (percentage points) to flag a signal
DIVERGENCE_THRESHOLD=10

# Sport key for The Odds API (e.g. soccer_epl, soccer_uefa_champs_league)
SPORT_KEY=soccer_epl

# Poll interval in seconds
POLL_INTERVAL=300

# ── Long-term holding analytics ──────────────────────────────────────────────
# Risk-free rate (annualised) used in Sharpe/Sortino. 0.04 ≈ 1y T-bill.
LONG_TERM_RF_RATE=0.04

# Optional: Glassnode API key for richer on-chain coverage. Leave unset to use
# the free CoinMetrics Community tier (BTC + ETH only).
# GLASSNODE_API_KEY=
