# ── Gateway SSO ─────────────────────────────────────────────────────────────
# Shared secret with gateway/.env. Required when running behind the gateway.
GATEWAY_SSO_SECRET=

# ── Server ──────────────────────────────────────────────────────────────────
# Port the FastAPI backend listens on. Gateway expects 8051.
PORT=8051

# CORS origin for the React/Vite dev server.
FRONTEND_ORIGIN=http://localhost:3000

# Set to any non-empty value to enable uvicorn auto-reload during development.
DEV=

# ── Admin bootstrap (used by deploy.sh) ─────────────────────────────────────
# Used by midterm-dashboard/deploy.sh to seed an admin user on first deploy.
ADMIN_EMAIL=
ADMIN_PASSWORD=
