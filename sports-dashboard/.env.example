# ── The Odds API ────────────────────────────────────────────────────────────
# Get a free key at https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# ── Polymarket / signal config ──────────────────────────────────────────────
POLYMARKET_HOST=https://clob.polymarket.com

# Sport key for The Odds API (e.g. soccer_epl, soccer_uefa_champs_league).
SPORT_KEY=soccer_epl

# Divergence threshold (percentage points) to flag a signal.
DIVERGENCE_THRESHOLD=5

# Poll interval in seconds.
POLL_INTERVAL=300

# ── Gateway SSO ─────────────────────────────────────────────────────────────
# Shared secret with gateway/.env. Required when running behind the gateway.
GATEWAY_SSO_SECRET=

# Set to 1 to bypass gateway auth when running standalone for local dev.
DEV_MODE=

# ── Cloudflare (optional) ───────────────────────────────────────────────────
# Origin allowed by Cloudflare Access (only set if fronting with cf-access).
CLOUDFLARE_ORIGIN=
