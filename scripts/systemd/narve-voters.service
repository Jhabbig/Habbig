[Unit]
Description=narve.ai voters service
After=network.target
StartLimitIntervalSec=60
StartLimitBurst=3

[Service]
Type=simple
User=julianhabbig
Group=julianhabbig
WorkingDirectory=/home/julianhabbig/Habbig/voters-dashboard
ExecStart=/usr/bin/python3 server.py
Restart=on-failure
RestartSec=5

# Hardening (narve doesn't need much; these are belt-and-suspenders)
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/home/julianhabbig/Habbig/voters-dashboard
ReadWritePaths=/tmp

# Env file path
EnvironmentFile=-/home/julianhabbig/Habbig/gateway/.env

# Stdout/stderr go to journald
StandardOutput=journal
StandardError=journal
SyslogIdentifier=narve-voters

[Install]
WantedBy=multi-user.target
