# Main server connection
MAIN_SERVER_URL=http://localhost:7000
SCRAPER_API_KEY=                            # shared secret, min 48 chars — generate with: openssl rand -hex 24

# Scraper API
SCRAPER_PORT=8001
SCRAPER_HOST=127.0.0.1                     # localhost only — not exposed publicly

# Scraping behaviour
TWITTER_INTERVAL_MINUTES=20
TRUTHSOCIAL_INTERVAL_MINUTES=15
RETRY_TRANSMISSION_INTERVAL_MINUTES=5
MAX_POSTS_PER_KEYWORD=100
MAX_TRANSMISSION_ATTEMPTS=10

# Rate limiting
TWITTER_DELAY_BETWEEN_KEYWORDS_SECONDS=45
TRUTHSOCIAL_DELAY_BETWEEN_KEYWORDS_SECONDS=30
MIN_DELAY_JITTER_SECONDS=10

# Browser
PLAYWRIGHT_HEADLESS=true
BROWSER_TYPE=chromium                      # chromium | firefox | webkit

# Storage
SCRAPER_DB_PATH=./scraper/scraper.db
SESSION_PROFILE_PATH=./scraper/stealth/profiles

# Logging
LOG_LEVEL=INFO
LOG_FILE=./scraper/logs/scraper.log

# TruthSocial prominent accounts (comma-separated, always scraped without auth)
TRUTHSOCIAL_PROMINENT_ACCOUNTS=realDonaldTrump,DonaldTrumpJr

# Twitter keywords (comma-separated, initial list — manageable via admin panel)
TWITTER_KEYWORDS=will win,% chance,predict,bet on,odds of,probability
# TruthSocial keywords
TRUTHSOCIAL_KEYWORDS=election,win,predict,poll
