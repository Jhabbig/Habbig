# ── Email relay (Claude Code over email) ────────────────────────────────────
# Subject grammar:
#   [<bot_key>] <prompt>    fresh Claude session in that bot's working dir
#   [list]                  list recent threads across all your project dirs
#   [list:<bot_key>]        list threads scoped to one bot
#   [<query>] <prompt>      resume an existing session — <query> can be a UUID
#                           prefix (≥6 hex chars) or a substring of the title
#                           (must uniquely match one session)
#
# Replies arrive in-thread. Bots can also push notifications to you via
# gateway/email_relay/notify.py — just `notify("centralbank", "msg", "details")`.

# IMAP — read inbox
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=you@gmail.com
# Generate at https://myaccount.google.com/apppasswords (NOT your Gmail password)
IMAP_PASS=xxxx-xxxx-xxxx-xxxx
IMAP_MAILBOX=INBOX

# SMTP — send replies and bot pushes (typically same Gmail creds)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Authorization — comma-separated list of addresses allowed to drive bots.
# Inbound emails from any other sender are ignored.
AUTHORIZED_FROM=you@gmail.com

# Where bot pushes (notify.py) get sent.
NOTIFY_TO=you@gmail.com

# Polling cadence (seconds). Gmail rate-limits aggressive polling — 60s is safe.
POLL_INTERVAL=60

# Path to claude CLI. Run `which claude` to find yours.
CLAUDE_BIN=/Users/julianhabbig/.local/bin/claude

# Hard timeout per Claude invocation (seconds).
CLAUDE_TIMEOUT=300
