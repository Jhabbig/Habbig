# narve.ai / Habbig Gateway — Environment Variables
# Copy to .env and fill in values before running.

# Server
PRODUCTION=0
SITE_ACCESS_TOKEN=
GATEWAY_COOKIE_SECRET=
GATEWAY_SSO_SECRET=
ENVIRONMENT=production
APP_VERSION=1.0.0

# Security — rate limiting and CSRF protection
# REDIS_URL enables cross-worker rate limiting (optional; falls back to in-memory)
# REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_ENABLED=true          # Set false to disable rate limiting in dev
CSRF_ENABLED=true                # Set false to disable CSRF in dev (never in prod)
TRUSTED_PROXY_IPS=               # Comma-separated trusted proxies for X-Forwarded-For

# CORS — allowed origins for cross-origin requests. Comma-separated.
# Restrict to known first-party hosts; never use "*" in production.
CORS_ORIGINS=https://narve.ai,https://staging.narve.ai

# SMTP (for password resets, enquiry notifications, feedback notifications)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# ENQUIRY_EMAIL=
# FEEDBACK_EMAIL=feedback@narve.ai

# Legal contacts (rendered on /terms, /privacy pages)
LEGAL_EMAIL=legal@narve.ai
PRIVACY_EMAIL=privacy@narve.ai
SUPPORT_EMAIL=support@narve.ai

# Market API endpoints (defaults are fine for production)
# POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
# POLYMARKET_CLOB_API=https://clob.polymarket.com
# KALSHI_API_BASE=https://trading-api.kalshi.com/trade-api/v2
# MARKETS_CACHE_TTL=300

# REQUIRED in prod — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_ENCRYPTION_KEY=

# Stripe — uncomment and fill when ready to enable payments
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_TRADER_MONTHLY=price_xxx
# STRIPE_PRICE_TRADER_ANNUAL=price_xxx
# STRIPE_PRICE_PRO_MONTHLY=price_xxx
# STRIPE_PRICE_PRO_ANNUAL=price_xxx
# STRIPE_PRICE_TRADING_ADDON_MONTHLY=price_xxx
# STRIPE_PRICE_TRADING_ADDON_ANNUAL=price_xxx

# Claude AI (Signal Search + Intelligence dashboard)
# ANTHROPIC_API_KEY=sk-ant-xxx

# Scraper service (runs on same server, port 8001)
# SCRAPER_URL=http://127.0.0.1:8001
# SCRAPER_API_KEY=                           # must match scraper's SCRAPER_API_KEY — generate with: openssl rand -hex 24

# Sentry — create two projects (backend + frontend) at sentry.io,
# copy both DSNs here. SENTRY_AUTH_TOKEN is optional and enables the
# "recent errors" widget on the admin System Health tab.
# SENTRY_DSN=                                # backend DSN (keep secret)
# SENTRY_DSN_PUBLIC=                         # frontend DSN (separate project, public key OK)
# SENTRY_AUTH_TOKEN=                         # sentry.io/settings/auth-tokens/
# SENTRY_ORG=                                # e.g. "narve"
# SENTRY_PROJECT=                            # e.g. "narve-backend"
# SENTRY_DASHBOARD_URL=https://sentry.io/organizations/narve/
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# ── Feature 1: Email system ─────────────────────────────────────────────
# Outbound transport — set EITHER EMAIL_RELAY_URL (MailChannels worker)
# OR SMTP_HOST (any SMTP provider). Precedence: DRY_RUN > RELAY > SMTP.
EMAIL_DRY_RUN=false                          # true in dev — logs instead of sending
EMAIL_FROM=noreply@narve.ai
EMAIL_FROM_NAME=narve.ai
# EMAIL_RELAY_URL=https://narve-email-relay.your-subdomain.workers.dev
# EMAIL_RELAY_SECRET=                        # shared secret with the Cloudflare Worker
# SMTP_HOST=smtp.mailchannels.net            # OR smtp.resend.com / email-smtp.eu-west-1.amazonaws.com / etc.
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
APP_URL=https://narve.ai

# Cloudflare Email Routing recipients (set these to your personal inbox)
EMAIL_SUPPORT=your-email@example.com
EMAIL_LEGAL=your-email@example.com
EMAIL_PRIVACY=your-email@example.com
EMAIL_FEEDBACK=your-email@example.com
EMAIL_DMARC=your-email@example.com

# ── Feature 10: Job queue ───────────────────────────────────────────────
# If REDIS_HOST is set AND arq is installed → ARQ/Redis backend.
# Otherwise → in-process asyncio backend (default, zero-ops, single-server).
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD is required when Redis is exposed (docker-compose redis service
# refuses to start without it). Generate with: openssl rand -hex 32
REDIS_PASSWORD=change-me-long-random-string

# Analytics
ANALYTICS_ENABLED=true

# ── BetterStack Logtail (log aggregation) ───────────────────────────────
# Create three "Sources" at betterstack.com/logtail — one per service — then
# paste each Source Token here. If any token is empty, that service falls
# back to local structured file logs only (plus the admin-panel ring buffer).
# LOGTAIL_TOKEN_APP=           # narve-app source token
# LOGTAIL_TOKEN_SCRAPER=       # narve-scraper source token
# LOGTAIL_TOKEN_WORKER=        # narve-worker source token

# ── Web Push (VAPID keys) ──────────────────────────────────────────────
# Generate with:
#   python -c "from py_vapid import Vapid01; v=Vapid01(); v.generate_keys(); v.save_key('vapid_private.pem'); v.save_public_key('vapid_public.pem')"
# Or use openssl:
#   openssl ecparam -genkey -name prime256v1 -noout -out vapid_private.pem
PUSH_VAPID_PRIVATE_KEY_PEM=

# ── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
# SERVICE_NAME is set by each process (app/scraper/worker) in docker-compose
# or systemd. Only override here for ad-hoc CLI runs.
# SERVICE_NAME=app
# LOG_RING_CAPACITY=500        # in-memory ring buffer size for admin panel

# ── Bots ─────────────────────────────────────────────────────────────────
# Telegram and Discord bots run as separate processes on the server.
# Empty values disable the bot (the process exits cleanly on startup).
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
# Chrome Web Store extension ID; blank for unpacked dev builds.
NARVE_EXTENSION_ID=

# ── Credentials encryption (Fernet) ──────────────────────────────────────
# Used for Kalshi bearer tokens + any other stored third-party secrets.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 32 url-safe base64 bytes. NEVER commit the value — staging and prod
# each have their own.
CREDENTIALS_ENCRYPTION_KEY=

# HMAC key for the browser-extension JWT. Falls back to GATEWAY_COOKIE_SECRET
# if unset — set it explicitly in production so the two key lifetimes
# stay independent.
EXTENSION_JWT_SECRET=

# ── Portfolio / integrations ─────────────────────────────────────────────
# Override these to point at staging / recorded fixtures without touching
# code.
POLYMARKET_API_BASE=https://clob.polymarket.com
KALSHI_API_BASE=https://trading-api.kalshi.com/trade-api/v2

# ── Insider-data fetchers (SEC EDGAR / FEC / congressional trades) ───────
SEC_EDGAR_USER_AGENT=narve.ai contact@narve.ai
FEC_API_KEY=
CAPITOLTRADES_API_KEY=
UNUSUALWHALES_API_KEY=
QUIVERQUANT_API_KEY=

# ── Stripe price IDs per subproduct (monthly) ────────────────────────────
# Leave blank to disable checkout for that subproduct — the landing
# page CTA falls back to a "contact" link when the price isn't set.
STRIPE_PRICE_ID_SPORTS_MONTHLY=
STRIPE_PRICE_ID_WEATHER_MONTHLY=
STRIPE_PRICE_ID_WORLD_MONTHLY=
STRIPE_PRICE_ID_CRYPTO_MONTHLY=
STRIPE_PRICE_ID_MIDTERM_MONTHLY=
STRIPE_PRICE_ID_TRADERS_MONTHLY=


# ═══════════════════════════════════════════════════════════════════════
# OBSERVABILITY — Sentry + BetterStack (LogTail)
# ═══════════════════════════════════════════════════════════════════════

# OPTIONAL — Sentry DSN for error + performance capture. Leave blank to
# disable Sentry entirely (no network calls, no SDK init).
SENTRY_DSN=
# OPTIONAL — identifies the service in Sentry / logs. Default narve-gateway.
SERVICE_NAME=narve-gateway
# OPTIONAL — sentry sampling. 0.0 disables traces/profiles; 1.0 captures all.
SENTRY_TRACES_SAMPLE_RATE=0.10
SENTRY_PROFILES_SAMPLE_RATE=0.10
# OPTIONAL — only used to build the "Open in Sentry" client-side link.
SENTRY_DASHBOARD_URL=
# OPTIONAL — the /admin/sentry tab calls the Sentry REST API. Needs
# project:read + issues:read scopes. Leave blank to hide the tab.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# OPTIONAL — BetterStack / LogTail source token for the "app" channel.
# When set, the log ring buffer additionally ships lines to BetterStack.
LOGTAIL_TOKEN_APP=

# ═══════════════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════════════

# OPTIONAL — DEBUG | INFO | WARNING | ERROR. Default INFO.
LOG_LEVEL=INFO
# OPTIONAL — JSON log file path. Unset = stdout + in-memory ring only.
LOG_FILE=
# OPTIONAL — in-memory ring buffer size for /admin/logs. Default 2000.
LOG_RING_CAPACITY=2000

# ═══════════════════════════════════════════════════════════════════════
# FEATURE TOGGLES (dev-only conveniences)
# ═══════════════════════════════════════════════════════════════════════

# OPTIONAL — caches market API responses in-memory. Set false to force
# fresh reads while debugging stale data.
CACHE_ENABLED=true
# OPTIONAL — disable the feedback-form rate limit in local dev so you
# can hammer the endpoint without 429s. NEVER set true in production.
FEEDBACK_RATELIMIT_DISABLED=false
# OPTIONAL — override the global per-IP request limit (per minute). Default 600.
GLOBAL_RATE_LIMIT_PER_MIN=600

# ═══════════════════════════════════════════════════════════════════════
# DATABASE PATHS
# ═══════════════════════════════════════════════════════════════════════

# OPTIONAL — override gateway sqlite file location (default auth.db).
# Tests set this to a tmp path.
GATEWAY_DB_PATH=
# OPTIONAL — separate sqlite for the scraper sidecar.
SCRAPER_DB_PATH=

# ═══════════════════════════════════════════════════════════════════════
# QUEUE BACKEND
# ═══════════════════════════════════════════════════════════════════════

# OPTIONAL — Redis URL for ARQ. When set AND the ``arq`` pkg is installed,
# jobs.backend uses Redis; otherwise InProcessBackend (asyncio + SQLite
# audit table). See jobs/__init__.py docstring.
REDIS_URL=
# OPTIONAL — Redis password when REDIS_URL doesn't embed it.
REDIS_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════
# SCRAPER SIDECAR — talks HTTP to the main gateway at MAIN_SERVER_URL
# ═══════════════════════════════════════════════════════════════════════

# REQUIRED if scraper runs — URL of the main gateway (no trailing slash).
# Scraper POSTs extracted posts here.
MAIN_SERVER_URL=http://localhost:8000
# REQUIRED if scraper runs — shared secret between gateway + scraper.
# Gateway rejects scraper POSTs without a matching Authorization header.
SCRAPER_API_KEY=
# OPTIONAL — scraper's own debug HTTP bind.
SCRAPER_HOST=0.0.0.0
SCRAPER_PORT=8080

# Scraper tuning — defaults sensible, override for aggressive dev or
# politer prod rates.
MAX_POSTS_PER_KEYWORD=50
MIN_DELAY_JITTER_SECONDS=3.0
MAX_TRANSMISSION_ATTEMPTS=3
RETRY_TRANSMISSION_INTERVAL_MINUTES=5

# Twitter scraper
TWITTER_KEYWORDS=
TWITTER_INTERVAL_MINUTES=15
TWITTER_DELAY_BETWEEN_KEYWORDS_SECONDS=5

# TruthSocial scraper
TRUTHSOCIAL_KEYWORDS=
TRUTHSOCIAL_PROMINENT_ACCOUNTS=
TRUTHSOCIAL_INTERVAL_MINUTES=30
TRUTHSOCIAL_DELAY_BETWEEN_KEYWORDS_SECONDS=5

# Playwright (small subset of scrapers).
BROWSER_TYPE=chromium
PLAYWRIGHT_HEADLESS=true
# OPTIONAL — persisted browser profile so cookies survive restarts.
SESSION_PROFILE_PATH=

# ─── Backup — offsite weekly encrypted push ─────────────────────────────
# Consumed by scripts/backup_offsite.sh (wired into cron by
# scripts/install_backup_cron.sh). Both REQUIRED for the weekly job to
# run; absence fails the cron loud rather than silently no-op.
#
# GPG public key identity that encrypts the snapshot. Must already be
# imported + trusted on the host (`gpg --edit-key <id> trust`).
BACKUP_GPG_RECIPIENT=
# rsync target, host:path form. SSH key must be in known_hosts on the host.
BACKUP_OFFSITE_RSYNC_TARGET=
# Extra rsync flags; default "-e ssh" is fine for most setups.
BACKUP_OFFSITE_RSYNC_OPTS=
# Weeks to retain offsite (remote find + delete). Default 12 (≈3 months).
BACKUP_OFFSITE_RETENTION_WEEKS=12
# Address that cron failure mail goes to. Appears in /etc/cron.d/narve-backup.
BACKUP_MAILTO=ops@narve.ai
