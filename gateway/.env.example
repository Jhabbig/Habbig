# ── Gateway ─────────────────────────────────────────────────────────────────
PRODUCTION=0
GATEWAY_COOKIE_SECRET=change-me-to-a-random-string
GATEWAY_SSO_SECRET=shared-secret-between-gateway-and-dashboards

# ── Stripe (billing) ───────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (password resets, enquiry notifications) ──────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# ENQUIRY_EMAIL=notifications@yourdomain.com

# ── Voter Pulse: AI narrative (Claude API) ──────────────────────────────────
# Optional. Without it the "TODAY" banner is hidden but the dashboard still
# renders. Get a key at https://console.anthropic.com.
# ANTHROPIC_API_KEY=sk-ant-...
# VOTER_PULSE_NARRATIVE_MODEL=claude-haiku-4-5-20251001
