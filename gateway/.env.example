# narve.ai / Habbig Gateway — Environment Variables
# Copy to .env and fill in values before running.

# Server
PRODUCTION=0
SITE_ACCESS_TOKEN=
GATEWAY_COOKIE_SECRET=
GATEWAY_SSO_SECRET=
ENVIRONMENT=production
APP_VERSION=1.0.0

# Security — rate limiting and CSRF protection
# REDIS_URL enables cross-worker rate limiting (optional; falls back to in-memory)
# REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_ENABLED=true          # Set false to disable rate limiting in dev
CSRF_ENABLED=true                # Set false to disable CSRF in dev (never in prod)
TRUSTED_PROXY_IPS=               # Comma-separated trusted proxies for X-Forwarded-For

# SMTP (for password resets, enquiry notifications, feedback notifications)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# ENQUIRY_EMAIL=
# FEEDBACK_EMAIL=feedback@narve.ai

# Legal contacts (rendered on /terms, /privacy pages)
LEGAL_EMAIL=legal@narve.ai
PRIVACY_EMAIL=privacy@narve.ai
SUPPORT_EMAIL=support@narve.ai

# Market API endpoints (defaults are fine for production)
# POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
# POLYMARKET_CLOB_API=https://clob.polymarket.com
# KALSHI_API_BASE=https://trading-api.kalshi.com/trade-api/v2
# MARKETS_CACHE_TTL=300

# Credential encryption key (generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# CREDENTIALS_ENCRYPTION_KEY=

# Stripe — uncomment and fill when ready to enable payments
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_TRADER_MONTHLY=price_xxx
# STRIPE_PRICE_TRADER_ANNUAL=price_xxx
# STRIPE_PRICE_PRO_MONTHLY=price_xxx
# STRIPE_PRICE_PRO_ANNUAL=price_xxx
# STRIPE_PRICE_TRADING_ADDON_MONTHLY=price_xxx
# STRIPE_PRICE_TRADING_ADDON_ANNUAL=price_xxx

# Claude AI (Signal Search + Intelligence dashboard)
# ANTHROPIC_API_KEY=sk-ant-xxx

# Scraper service (runs on same server, port 8001)
# SCRAPER_URL=http://127.0.0.1:8001
# SCRAPER_API_KEY=                           # must match scraper's SCRAPER_API_KEY — generate with: openssl rand -hex 24

# Sentry — create two projects (backend + frontend) at sentry.io,
# copy both DSNs here. SENTRY_AUTH_TOKEN is optional and enables the
# "recent errors" widget on the admin System Health tab.
# SENTRY_DSN=                                # backend DSN (keep secret)
# SENTRY_DSN_PUBLIC=                         # frontend DSN (separate project, public key OK)
# SENTRY_AUTH_TOKEN=                         # sentry.io/settings/auth-tokens/
# SENTRY_ORG=                                # e.g. "narve"
# SENTRY_PROJECT=                            # e.g. "narve-backend"
# SENTRY_DASHBOARD_URL=https://sentry.io/organizations/narve/
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# ── Feature 1: Email system ─────────────────────────────────────────────
# Outbound transport — set EITHER EMAIL_RELAY_URL (MailChannels worker)
# OR SMTP_HOST (any SMTP provider). Precedence: DRY_RUN > RELAY > SMTP.
EMAIL_DRY_RUN=false                          # true in dev — logs instead of sending
EMAIL_FROM=noreply@narve.ai
EMAIL_FROM_NAME=narve.ai
# EMAIL_RELAY_URL=https://narve-email-relay.your-subdomain.workers.dev
# EMAIL_RELAY_SECRET=                        # shared secret with the Cloudflare Worker
# SMTP_HOST=smtp.mailchannels.net            # OR smtp.resend.com / email-smtp.eu-west-1.amazonaws.com / etc.
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
APP_URL=https://narve.ai

# Cloudflare Email Routing recipients (set these to your personal inbox)
EMAIL_SUPPORT=shocakarel@gmail.com
EMAIL_LEGAL=shocakarel@gmail.com
EMAIL_PRIVACY=shocakarel@gmail.com
EMAIL_FEEDBACK=shocakarel@gmail.com
EMAIL_DMARC=shocakarel@gmail.com

# ── Feature 10: Job queue ───────────────────────────────────────────────
# If REDIS_HOST is set AND arq is installed → ARQ/Redis backend.
# Otherwise → in-process asyncio backend (default, zero-ops, single-server).
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# Analytics
ANALYTICS_ENABLED=true

# ── BetterStack Logtail (log aggregation) ───────────────────────────────
# Create three "Sources" at betterstack.com/logtail — one per service — then
# paste each Source Token here. If any token is empty, that service falls
# back to local structured file logs only (plus the admin-panel ring buffer).
# LOGTAIL_TOKEN_APP=           # narve-app source token
# LOGTAIL_TOKEN_SCRAPER=       # narve-scraper source token
# LOGTAIL_TOKEN_WORKER=        # narve-worker source token

# ── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
# SERVICE_NAME is set by each process (app/scraper/worker) in docker-compose
# or systemd. Only override here for ad-hoc CLI runs.
# SERVICE_NAME=app
# LOG_RING_CAPACITY=500        # in-memory ring buffer size for admin panel
