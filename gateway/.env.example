# ── Supabase (required) ─────────────────────────────────────────────────────
# Create a project at https://supabase.com, then find these in:
# Project Settings > API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...

# ── Gateway ─────────────────────────────────────────────────────────────────
PRODUCTION=0
GATEWAY_COOKIE_SECRET=change-me-to-a-random-string
GATEWAY_SSO_SECRET=shared-secret-between-gateway-and-dashboards

# ── Stripe (billing) ───────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (password resets, enquiry notifications) ──────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# ENQUIRY_EMAIL=notifications@yourdomain.com
