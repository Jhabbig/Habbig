# ─── docker-compose template ─────────────────────────────────────────────────
# Copy to gateway/.env.production and fill in real values before
# running `docker compose up`. This file is the env_file source for
# every dashboard service except crypto and sports (which use their
# own .env files inside their dashboard directories).

# ── Required ────────────────────────────────────────────────────────────────
PRODUCTION=1
GATEWAY_SSO_SECRET=replace-me-with-a-shared-secret-between-gateway-and-dashboards
GATEWAY_COOKIE_SECRET=replace-me-with-a-random-32-byte-string

# DEV_MODE=0 here keeps the dashboards' fail-closed behavior intact.
# Set DEV_MODE=1 only for local one-host development; never in real prod.
DEV_MODE=0

# ── Optional: Redis (set REDIS_PASSWORD via the host shell, not this file) ───
# REDIS_PASSWORD is read from the shell environment by compose's
# ${REDIS_PASSWORD:?...} interpolation, not from env_file.

# ── Optional: Stripe (only needed for the gateway's billing flows) ──────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Optional: SMTP (only needed for password reset / enquiry emails) ────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# ENQUIRY_EMAIL=notifications@yourdomain.com
