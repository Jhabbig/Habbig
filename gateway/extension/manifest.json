{
  "manifest_version": 3,
  "name": "narve.ai — Prediction Market Intelligence",
  "version": "1.0.0",
  "description": "Overlay narve.ai intelligence on Polymarket markets — credibility scores, EV analysis, source signals",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://polymarket.com/*",
    "https://narve.ai/*",
    "https://api.narve.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://polymarket.com/event/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
