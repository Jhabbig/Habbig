# ── Flask ───────────────────────────────────────────────────────────────────
# Session signing key. If unset, a random key is generated each restart
# (sessions won't persist across restarts).
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
FLASK_SECRET=

# Set to 1 to enable Flask debug mode (auto-reload, debugger). Never in prod.
FLASK_DEBUG=0

# Set to 1 in production. Used by the WSGI runner branch.
PRODUCTION=0

# ── Gateway SSO ─────────────────────────────────────────────────────────────
# Shared secret with gateway/.env. Required when running behind the gateway.
GATEWAY_SSO_SECRET=

# Set to 1 to bypass gateway auth when running standalone for local dev.
DEV_MODE=

# ── LLM provider (insight engine) ───────────────────────────────────────────
# "anthropic" (default) uses Claude via the API and requires ANTHROPIC_API_KEY.
# "local" routes to an Ollama-compatible server at OLLAMA_BASE_URL — zero
# per-call cost, requires you to be running Ollama (or LM Studio / vLLM /
# llama.cpp's server) at that URL.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Local-only (ignored when LLM_PROVIDER=anthropic).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_FAST=llama3.1:8b
OLLAMA_MODEL_DEEP=llama3.3:70b
OLLAMA_MODEL_EXTRA=qwen2.5:14b
OLLAMA_TIMEOUT=120

# ── Auto-mode (insight engine background loop) ──────────────────────────────
# Auto-mode is OFF by default — set INSIGHT_AUTO_PER_PASS to a positive
# integer to enable. At Anthropic prices, 10 calls/pass × 12 passes/hr is
# ~$8/day if every market is novel.  Setting to 0 disables the loop while
# letting on-demand /api/insight calls keep working.
INSIGHT_AUTO_PER_PASS=0
INSIGHT_AUTO_INTERVAL_SECONDS=300
INSIGHT_AUTO_DEDUP_HOURS=6
INSIGHT_AUTO_MIN_EDGE=0.10
