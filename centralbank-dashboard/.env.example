# centralbank-dashboard environment variables.
#
# Copy to `.env` and fill in. The dashboard runs fine without any of these —
# it falls back to data/rates_snapshot.yaml — but live data needs FRED.

# ── FRED (US Federal Reserve rates) ────────────────────────────────────
# Free signup at https://fred.stlouisfed.org/docs/api/api_key.html
# Without this, the Fed rate is served from the YAML snapshot.
FRED_API_KEY=

# ── Offline override ───────────────────────────────────────────────────
# Set to "1" to disable all external HTTP fetches (FRED, ECB SDW, BoE,
# Polymarket). The dashboard serves only the YAML snapshot. Useful in
# tests, CI, and air-gapped environments.
CENTRALBANK_OFFLINE=0

# ── Gateway SSO ────────────────────────────────────────────────────────
# Shared secret with the narve.ai gateway. Without this, the dashboard
# rejects every gateway-fronted request (401). Generate via:
#   openssl rand -hex 32
GATEWAY_SSO_SECRET=

# Set to "1" to bypass gateway auth locally (synthetic dev user).
DEV_MODE=1

# ── Polymarket source ──────────────────────────────────────────────────
# The gateway exposes /sources/polymarket on its internal port. Override
# only if the gateway lives somewhere unusual.
# GATEWAY_POLYMARKET_URL=http://127.0.0.1:7000/sources/polymarket

# ── Server bind ────────────────────────────────────────────────────────
# The gateway proxies to 127.0.0.1:7061. Override only for debugging.
PORT=7061
BIND_HOST=127.0.0.1
