# ── Gateway SSO ─────────────────────────────────────────────────────────────
# Shared secret with gateway/.env. Required when running behind the gateway.
GATEWAY_SSO_SECRET=

# Set to 1 to bypass gateway auth when running standalone for local dev.
DEV_MODE=

# ── X / Twitter (optional) ──────────────────────────────────────────────────
# Bearer token for the X API v2. Used to fetch geopolitical updates.
# Get one at https://developer.x.com — leave blank to disable the X feed.
X_BEARER_TOKEN=
