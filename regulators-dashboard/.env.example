# Required when running behind the gateway. Must match gateway/.env.
GATEWAY_SSO_SECRET=

# Set to 1 to bypass gateway auth for local dev.
DEV_MODE=1

# Override default port (7080).
# PORT=7080

# Where v1.4 persists per-day OFAC SDN snapshots. Mount a persistent
# volume here in production so day-over-day deltas survive restart.
# Defaults to a tempfile path that loses state across restarts.
# SDN_SNAPSHOT_DIR=/var/lib/regulators-dashboard/sdn-snapshots
