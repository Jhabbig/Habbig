# Required when running behind the gateway. Must match gateway/.env.
GATEWAY_SSO_SECRET=

# Set to 1 to bypass gateway auth for local dev.
DEV_MODE=1

# Override default port (7080).
# PORT=7080

# Where v1.4 persists per-day OFAC SDN snapshots. Mount a persistent
# volume here in production so day-over-day deltas survive restart.
# Defaults to a tempfile path that loses state across restarts.
# SDN_SNAPSHOT_DIR=/var/lib/regulators-dashboard/sdn-snapshots

# Token gate for /feed.xml (v1.5 RSS alert feed). RSS readers can't
# send the gateway-SSO header, so /feed.xml bypasses it and requires
# `?token=<value>` here instead. Leave unset in DEV_MODE; required in
# any deployed environment where the dashboard data isn't fully public.
# RSS_SHARED_TOKEN=

# v1.6 — email digest configuration.
#
# SMTP settings. If SMTP_HOST is unset, the sender DRY_RUNs (logs
# instead of sending) — useful for staging without delivery exposure.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@regulators.example.com
# SMTP_STARTTLS=1
#
# Where v1.6 persists the SQLite subscriber DB. Mount a persistent
# volume here in production so subscriptions survive container restart.
# DIGEST_DB_PATH=/var/lib/regulators-dashboard/digest.sqlite
#
# Admin token for POST /api/digest/send_now. External cron / k8s
# CronJob hits the endpoint with `?token=<value>` or `X-Admin-Token`
# header. Required outside DEV_MODE.
# DIGEST_ADMIN_TOKEN=
#
# Used in email subscribe / unsubscribe links. Required in production
# so links don't expose the internal scheme/port. Defaults to the
# request URL's origin (fine for DEV_MODE).
# PUBLIC_BASE_URL=https://regulators.example.com
