[Unit]
Description=Narve Voters Atlas Dashboard (port 7051)
After=network.target

[Service]
# Loads the shared gateway .env so the dashboard can verify X-Gateway-Secret
# on incoming proxied requests.
Type=simple
User=julianhabbig
WorkingDirectory=/home/julianhabbig/Polymarket/voters-dashboard
ExecStart=/home/julianhabbig/Polymarket/venv/bin/python -m uvicorn server:app --host 127.0.0.1 --port 7051
Restart=always
RestartSec=5
EnvironmentFile=-/home/julianhabbig/Polymarket/gateway/.env.production

# Hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
PrivateTmp=true
ReadWritePaths=/home/julianhabbig/Polymarket/voters-dashboard
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictNamespaces=true
RestrictSUIDSGID=true
LockPersonality=true

[Install]
WantedBy=multi-user.target
