# ── Gateway SSO ─────────────────────────────────────────────────────────────
# Shared secret with gateway/.env. Required when running behind the gateway.
GATEWAY_SSO_SECRET=

# Set to 1 to bypass gateway auth when running standalone for local dev.
DEV_MODE=

# ── EDGAR ───────────────────────────────────────────────────────────────────
# SEC requires a User-Agent that includes contact info. Override the default
# in production with a real address.
EDGAR_USER_AGENT=narve.ai whale tracker contact@narve.ai

# ── Ingest ──────────────────────────────────────────────────────────────────
# How often the background loop pulls EDGAR (seconds). Default: 300.
INGEST_INTERVAL_S=300

# Number of entries pulled from each Atom feed per pass. Default: 40.
INGEST_FEED_COUNT=40

# Set to 1 to disable the background ingest loop (useful when running multiple
# replicas — only one should ingest).
DISABLE_INGEST=
