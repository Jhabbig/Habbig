# ── Gateway SSO ─────────────────────────────────────────────────────────────
# Shared secret with gateway/.env. Required when running behind the gateway.
GATEWAY_SSO_SECRET=

# Set to 1 to bypass gateway auth when running standalone for local dev.
DEV_MODE=

# ── EDGAR ───────────────────────────────────────────────────────────────────
# SEC requires a User-Agent that includes contact info. Override the default
# in production with a real address.
EDGAR_USER_AGENT=narve.ai whale tracker contact@narve.ai

# ── Ingest ──────────────────────────────────────────────────────────────────
# How often the background loop pulls EDGAR (seconds). Default: 300.
INGEST_INTERVAL_S=300

# Number of entries pulled from each Atom feed per pass. Default: 40.
INGEST_FEED_COUNT=40

# Set to 1 to disable the background ingest loop (useful when running multiple
# replicas — only one should ingest).
DISABLE_INGEST=

# ── Bayesian skill ──────────────────────────────────────────────────────────
# How often the skill labeler runs (seconds). Default 1800 = 30 min.
SKILL_INTERVAL_S=1800

# Max outcomes labeled per pass. Default 200.
SKILL_PER_PASS=200

# Forward-return horizon used for the skill posterior. Default 30 days.
SKILL_HORIZON_DAYS=30

# User-Agent header used when fetching daily-price data from Stooq.
PRICES_USER_AGENT=narve.ai whale tracker contact@narve.ai

# ── Options flow + dark pool (paid) ────────────────────────────────────────
# Set to enable the Options Flow and Dark Pool tabs. Without a key, those
# tabs render an "unconfigured" message and ingest is a no-op.
UNUSUAL_WHALES_API_KEY=
UNUSUAL_WHALES_BASE_URL=https://api.unusualwhales.com
OPTIONS_FLOW_USER_AGENT=narve.ai whale tracker contact@narve.ai
OPTIONS_FLOW_INTERVAL_S=120
OPTIONS_FLOW_LIMIT=200

# ── CUSIP → ticker resolution (OpenFIGI) ────────────────────────────────────
# Free without a key (25 req/min, batches of 10). Set OPENFIGI_API_KEY for
# higher throughput (25 req/min, batches of 100).
OPENFIGI_API_KEY=
OPENFIGI_INTERVAL_S=1800
OPENFIGI_PER_PASS=500

# ── Local LLM extraction (filings → structured fields) ─────────────────────
# Points at any OpenAI-compatible /v1/chat/completions endpoint. Defaults
# to Ollama on localhost. Recommended model: qwen2.5:7b-instruct (great at
# structured JSON; ~5GB Q4 fits on a laptop GPU). Run once:
#   ollama pull qwen2.5:7b-instruct && ollama serve
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b-instruct
LLM_API_KEY=ollama
LLM_TIMEOUT_S=180
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=1024
LLM_CONCURRENCY=1

# How often the background extractor runs, and how many filings per pass.
LLM_EXTRACT_INTERVAL_S=600
LLM_EXTRACT_PER_PASS=10

# ── Watchlist alert delivery ───────────────────────────────────────────────
# Webhook/Slack/Discord channels need no global config (URL per-rule).
# Email channel uses SMTP:
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=whale-tracker@narve.ai

# How often the alert evaluator runs (seconds). Default 60.
ALERT_INTERVAL_S=60

# How often the identity-graph rebuild runs (seconds). Default hourly.
IDENTITY_INTERVAL_S=3600

# ── UK Companies House (PSC notices) ──────────────────────────────────────
# Free key from https://developer.company-information.service.gov.uk/
# Watchlist-based: POST /api/uk/companies to add UK company numbers,
# then PSC refreshes every UK_INTERVAL_S seconds (default 6 hours).
UK_COMPANIES_HOUSE_API_KEY=
UK_COMPANIES_HOUSE_BASE_URL=https://api.company-information.service.gov.uk
UK_INTERVAL_S=21600
