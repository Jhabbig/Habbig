# Gateway SSO secret. MUST match the value in gateway/.env. When unset and
# DEV_MODE=1, all requests are accepted - use for local dev only.
GATEWAY_SSO_SECRET=

# Set to 1 to bypass SSO entirely. Never set in production.
DEV_MODE=

# Listen port (default 7054).
PORT=7054

# Bind host (default 0.0.0.0).
BIND_HOST=0.0.0.0

# Background pre-fetch loop. Set to 1/true/yes to enable. The loop walks
# 15 ingestion jobs on staggered schedules so page loads return from cache.
CT_PREFETCH=

# Override disk-cache directory (default: ./cache/ next to server.py).
CT_CACHE_DIR=
