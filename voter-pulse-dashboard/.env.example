# Voter Pulse Dashboard
PORT=7062
BIND_HOST=0.0.0.0

# Gateway-SSO secret. Set DEV_MODE=1 instead when running standalone locally.
GATEWAY_SSO_SECRET=
DEV_MODE=

# AI narrative (v6) — Claude API key. Without this the dashboard still
# renders; only the top-of-page "TODAY" narrative goes dark.
ANTHROPIC_API_KEY=
# Optional model override. Default: claude-haiku-4-5-20251001 (cheap & fast).
VOTER_PULSE_NARRATIVE_MODEL=

# Optional polling-source overrides (default: archived FiveThirtyEight CSVs)
VOTER_PULSE_APPROVAL_CSV=
VOTER_PULSE_GENERIC_BALLOT_CSV=

# Email alerts (v9) — SMTP credentials (typically inherited from gateway/.env.production)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=alerts@narve.ai
# SMTP_PASS=app-specific-password
# SMTP_SSL=0
# ALERT_FROM_EMAIL=alerts@narve.ai
# Signing secret for unsubscribe links (REQUIRED for production; falls back to
# GATEWAY_SSO_SECRET otherwise, which is fine for a tiny site but means a
# leak of one compromises the other).
# ALERT_SIGNING_SECRET=long-random-string
# How many points the mood must move before we fire an alert. Default 5.
# ALERT_THRESHOLD_POINTS=5
# Minimum seconds between alerts even if the mood keeps moving. Default 6h.
# ALERT_MIN_INTERVAL_SECONDS=21600
# Public URL used in the unsubscribe link in outbound emails.
# PUBLIC_DASHBOARD_URL=https://pulse.narve.ai
# SQLite path for subscribers + alert state. Default /app/data/voter_pulse.db.
# VOTER_PULSE_DB=/app/data/voter_pulse.db
