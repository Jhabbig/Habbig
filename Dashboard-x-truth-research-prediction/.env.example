# X (Twitter) — Basic tier required ($100/month), Bearer Token only needed
TWITTER_BEARER_TOKEN=
TWITTER_MONTHLY_QUOTA=10000

# TruthSocial — free, no API key needed for public accounts
TRUTHSOCIAL_USERNAME=
TRUTHSOCIAL_PASSWORD=
TRUTHSOCIAL_ACCESS_TOKEN=
TRUTHSOCIAL_API_BASE_URL=https://truthsocial.com

# Dashboard Auth
DASHBOARD_USER=admin
# REQUIRED: Set a strong password. The app will refuse to start without one.
DASHBOARD_PASSWORD=

# Anthropic — LLM extractor fallback (optional but strongly recommended)
# When set, posts that don't match any of the regex patterns are sent to Claude
# for structured prediction extraction. Catches roughly 3-5x more signal than
# regex alone (natural-language predictions, multi-clause sentences, etc.).
# Results are cached by content hash so repeat posts cost nothing.
ANTHROPIC_API_KEY=
# Model to use for extraction. Defaults to claude-opus-4-7. Swap to
# claude-haiku-4-5 if cost matters more than recall (~5x cheaper, slightly less accurate).
LLM_EXTRACTOR_MODEL=claude-opus-4-7
# Set to 0 to force-disable LLM extraction even if the API key is set.
LLM_EXTRACTION_ENABLED=1

# App
DATABASE_URL=sqlite+aiosqlite:///./predictions.db
LOG_LEVEL=INFO
