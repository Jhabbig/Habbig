# SEC EDGAR requires a descriptive User-Agent with contact email.
# Without this, EDGAR will rate-limit or block requests.
# See https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT="WhaleDashboard contact@example.com"

# Shared secret with the gateway for SSO header verification.
GATEWAY_SSO_SECRET=changeme

# FastAPI server port.
PORT=8053

# Optional: OpenFIGI API key for authoritative CUSIP→ticker resolution.
# Without a key the seeder still works at 25 jobs/min in batches of 10;
# with a key it runs at 250 jobs / 6s in batches of 100.
# Get one free at https://www.openfigi.com/api
OPENFIGI_API_KEY=

# Optional: SMTP credentials for direct alert email delivery. If unset,
# email-type alert rules write delivery rows with status='skipped_email'
# and the gateway picks them up. Set all four to deliver in-process.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Whale Watch <alerts@example.com>"
