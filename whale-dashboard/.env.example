# whale-dashboard environment variables.
#
# Copy to `.env` and adjust. Most defaults are sane for local dev.

# ── SEC EDGAR ──────────────────────────────────────────────────────────
# Mandatory per SEC's fair-access policy. Missing/empty UA → 403 from
# data.sec.gov. Format: "Project Name contact@email".
# See https://www.sec.gov/os/accessing-edgar-data
EDGAR_USER_AGENT="narve.ai sho@cakarel.com"

# Inter-request delay in seconds. EDGAR caps at ~10 req/s globally.
# 0.15 ≈ 6.6 req/s — well inside the limit.
EDGAR_RATE_DELAY=0.15

# How often the server re-runs the EDGAR sweep (seconds). 86400 = daily.
EDGAR_REFRESH_SECONDS=86400

# Set to "1" to disable the background EDGAR refresh loop (tests / CI).
# EDGAR_DISABLE_SCHEDULER=1

# Per-request HTTP timeout in seconds.
EDGAR_HTTP_TIMEOUT=20.0

# ── Gateway SSO ────────────────────────────────────────────────────────
# Shared secret with the narve.ai gateway. Without this, the dashboard
# rejects every gateway-fronted request (401). Generate via:
#   openssl rand -hex 32
GATEWAY_SSO_SECRET=

# Set to "1" to bypass gateway auth locally (synthetic dev user).
DEV_MODE=1

# ── Server bind ────────────────────────────────────────────────────────
# The gateway proxies to 127.0.0.1:8053. Override only for debugging.
PORT=8053
BIND_HOST=127.0.0.1

# ── Storage ────────────────────────────────────────────────────────────
# SQLite file. Default is `whale.sqlite` next to server.py.
# WHALE_DB_PATH=/var/lib/narve/whale.sqlite
