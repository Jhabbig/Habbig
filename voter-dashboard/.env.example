# Voter Sentiment Dashboard
# All upstream sources are keyless (FRED public CSV + Polymarket Gamma API),
# so there are no required secrets.

# Override default port (7053).
# PORT=7053

# Required when running behind the gateway. Must match gateway/.env.
# GATEWAY_SSO_SECRET=

# Set to 1 to bypass gateway auth for local dev.
# DEV_MODE=1
