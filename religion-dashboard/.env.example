# Required when running behind the gateway. Must match gateway/.env.
GATEWAY_SSO_SECRET=

# Set to 1 to bypass gateway auth for local dev.
DEV_MODE=1

# Override default port (7062).
# PORT=7062

# Vatican scraper: by default fetches press.vatican.va. Set this to read
# the cardinals HTML from a local file instead (useful for offline / dev
# environments without external network access).
# VATICAN_FIXTURE_PATH=/app/test_fixtures/vatican_sample.html
