# Required when running behind the gateway. Must match gateway/.env.
GATEWAY_SSO_SECRET=

# Set to 1 to bypass gateway auth for local dev.
DEV_MODE=1

# Override default port (7062).
# PORT=7062

# Vatican scraper: by default fetches press.vatican.va. Set this to read
# the cardinals HTML from a local file instead (useful for offline / dev
# environments without external network access).
# VATICAN_FIXTURE_PATH=/app/test_fixtures/vatican_sample.html

# ACLED religious-violence feed. Register at acleddata.com to get a key.
# When either var is missing the /api/violence endpoint returns ok=false.
# ACLED_EMAIL=
# ACLED_API_KEY=

# Alerts / webhooks. ALERTS_HMAC_SECRET is the bearer secret required to
# POST/GET/DELETE /api/alerts; outgoing webhook POSTs are signed with this
# same secret in the X-Religion-Signature header. If unset, a random secret
# is generated on each restart (so subscriptions effectively reset).
# ALERTS_HMAC_SECRET=
# ALERTS_DB_PATH=/app/data/alerts.sqlite
# DISABLE_ALERTS=0   # set to 1 to disable the background alert thread
