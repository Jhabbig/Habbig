# =============================================================================
# Culture Dashboard — env reference
# =============================================================================
# All keys are optional. Missing keys cause that source to be skipped, not a
# crash. See README for which sources need which key.

# ── Gateway SSO (required when running behind the gateway) ───────────────────
GATEWAY_SSO_SECRET=
DEV_MODE=1

# ── TikTok ───────────────────────────────────────────────────────────────────
# Pluggable backends, picked in this order:
#   1. APIFY_TOKEN       → robust paid scraping (recommended)
#   2. RAPIDAPI_KEY      → ScrapTik / TikAPI on RapidAPI
#   3. TIKTOK_MS_TOKEN   → unofficial TikTokApi (free, fragile)
APIFY_TOKEN=
RAPIDAPI_KEY=
TIKTOK_MS_TOKEN=

# ── Instagram ────────────────────────────────────────────────────────────────
# Same backend hierarchy as TikTok, plus optional login for unofficial libs.
# Logging into a real account from a server may get the account banned —
# consider a throwaway.
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# ── Reddit (free, but rate-limited without creds) ───────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=culture-dashboard/0.1

# ── YouTube Data API v3 ─────────────────────────────────────────────────────
YOUTUBE_API_KEY=

# ── X / Twitter (optional — used for trending + meme attribution) ───────────
X_BEARER_TOKEN=

# ── Spotify (optional — for chart context beyond the public charts page) ────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── News API (optional — falls back to RSS if missing) ──────────────────────
NEWSAPI_KEY=

# ── NYT Books API (optional — falls back to public bestsellers HTML) ───────
NYT_BOOKS_API_KEY=

# ── Cache / scheduler tuning ────────────────────────────────────────────────
CULTURE_DB_PATH=culture.db
CULTURE_REFRESH_INTERVAL=900   # seconds between background refresh sweeps
CULTURE_HTTP_TIMEOUT=15

# Perceptual-hash dedup. Higher = more aggressive merging, lower = stricter.
# 64-bit dHash; 8 catches crops/recompression without merging unrelated images.
CULTURE_PHASH_MAX_DISTANCE=8
