# =============================================================================
# Culture Dashboard — env reference
# =============================================================================
# All keys are optional. Missing keys cause that source to be skipped, not a
# crash. See README for which sources need which key.

# ── Gateway SSO (required when running behind the gateway) ───────────────────
GATEWAY_SSO_SECRET=
DEV_MODE=1

# ── TikTok ───────────────────────────────────────────────────────────────────
# Pluggable backends, picked in this order:
#   1. APIFY_TOKEN       → robust paid scraping (recommended)
#   2. RAPIDAPI_KEY      → ScrapTik / TikAPI on RapidAPI
#   3. TIKTOK_MS_TOKEN   → unofficial TikTokApi (free, fragile)
APIFY_TOKEN=
RAPIDAPI_KEY=
TIKTOK_MS_TOKEN=

# ── Instagram ────────────────────────────────────────────────────────────────
# Same backend hierarchy as TikTok, plus optional login for unofficial libs.
# Logging into a real account from a server may get the account banned —
# consider a throwaway.
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# ── Reddit (free, but rate-limited without creds) ───────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=culture-dashboard/0.1

# ── YouTube Data API v3 ─────────────────────────────────────────────────────
YOUTUBE_API_KEY=

# ── X / Twitter (optional — used for trending + meme attribution) ───────────
X_BEARER_TOKEN=

# ── Spotify (optional — for chart context beyond the public charts page) ────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── News API (optional — falls back to RSS if missing) ──────────────────────
NEWSAPI_KEY=

# ── NYT Books API (optional — falls back to public bestsellers HTML) ───────
NYT_BOOKS_API_KEY=

# ── Cache / scheduler tuning ────────────────────────────────────────────────
CULTURE_DB_PATH=culture.db
CULTURE_REFRESH_INTERVAL=900   # seconds between background refresh sweeps
CULTURE_HTTP_TIMEOUT=15

# Perceptual-hash dedup. Higher = more aggressive merging, lower = stricter.
# 64-bit dHash; 8 catches crops/recompression without merging unrelated images.
CULTURE_PHASH_MAX_DISTANCE=8

# ── Surge alerts ────────────────────────────────────────────────────────────
# z-score threshold above which the surge worker fires a webhook
SURGE_Z_THRESHOLD=2.5
# Cooldown per-item so one sustained surge doesn't spam alerts
SURGE_ALERT_COOLDOWN_HOURS=6
# Optional: POST surge events here (Slack/Discord webhook URL works directly
# if you wrap the JSON in a Slack-formatted message via a relay).
SURGE_WEBHOOK_URL=

# ── Cross-source topic clustering ───────────────────────────────────────────
# Jaccard threshold for grouping items into one topic. Higher = stricter.
CULTURE_TOPIC_MIN_OVERLAP=0.30
# Topic ↔ market matching threshold (also Jaccard)
CULTURE_EDGE_MIN_OVERLAP=0.25
# Minimum surge z-score for a topic to qualify as a "market signal" edge
CULTURE_EDGE_MIN_SIGNAL=1.5
# Penalty coefficient on |price_velocity_pct| when computing mispricing
# (mispricing = surge_signal − penalty × min|velocity|). 10 means a 30%
# market move cancels a z=3 surge signal.
CULTURE_EDGE_VELOCITY_PENALTY=10
# Trailing window (hours) for the market-price velocity calculation
CULTURE_PRICE_VELOCITY_HOURS=24
# Max bid-ask spread (basis points) before a market is filtered for thin
# liquidity. 500bps = 5% — wide enough to keep most low-volume markets but
# drop the dust.
CULTURE_MAX_SPREAD_BPS=500

# ── Signal validation / backtest ────────────────────────────────────────────
# Realised |Δ| threshold for a surge to count as a "hit"
CULTURE_BACKTEST_HIT_THRESHOLD=0.05
# Hours forward from a surge alert to measure realised price change
CULTURE_BACKTEST_WINDOW_HOURS=24

# ── Position sizing (informational only — quarter-Kelly suggestions) ────────
# Hard cap on suggested fraction-of-bankroll size.
CULTURE_POSITION_MAX_PCT=0.05
# Kelly fraction. Quarter-Kelly (0.25) is the standard cautious default.
CULTURE_POSITION_KELLY_FRACTION=0.25
# Implied probability edge per unit of mispricing score.
CULTURE_POSITION_EDGE_PER_Z=0.02

# ── LLM-powered "Today in culture" digest ───────────────────────────────────
# Required to enable the digest panel. Leave blank to disable.
ANTHROPIC_API_KEY=
# Model used for the digest. Haiku 4.5 is the default — flip to
# claude-opus-4-7 for richer prose at higher cost.
CULTURE_DIGEST_MODEL=claude-haiku-4-5
# Seconds between background digest regenerations (default 1h).
CULTURE_DIGEST_INTERVAL=3600
