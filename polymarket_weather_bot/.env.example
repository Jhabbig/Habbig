# Polymarket credentials
PRIVATE_KEY=your_private_key_here
POLYMARKET_API_KEY=your_api_key_here

# Kalshi credentials (optional — set KALSHI_ENABLED=true to activate)
KALSHI_ENABLED=false
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_MAX_TRADE_SIZE=100.0

# Trading config
PAPER_MODE=true
EDGE_THRESHOLD=0.08
BANKROLL=1000.0
MAX_POSITION_PCT=0.05
DAILY_LOSS_LIMIT_PCT=0.10
KELLY_FRACTION=0.15
MIN_LIQUIDITY=500.0
MAX_FORECAST_HOURS=48
RUN_INTERVAL_MINUTES=15

# Logging
LOG_LEVEL=INFO
DB_PATH=trades.db
